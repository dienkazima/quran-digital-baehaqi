{
  "expo": {
    "name": "Quran Digital – Baehaqi",
    "slug": "quran-digital-baehaqi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-app.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "qurandigital",
    "splash": {
      "image": "./assets/logo-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F3D3E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baehaqi.qurandigital"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-app.png",
        "backgroundColor": "#0F3D3E"
      },
      "package": "com.baehaqi.qurandigital",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo-app.png",
          "color": "#0F3D3E"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan aplikasi mengakses lokasi untuk menentukan waktu sholat yang akurat."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "802e00d5-eba7-4ccc-8c91-167dbf35a8a2"
      }
    }
  }
}
